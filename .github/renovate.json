{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>Boshen/renovate"],
  "ignorePaths": [
    "packages/cli/snap-tests/**",
    "packages/cli/snap-tests-global/**",
    "packages/cli/snap-tests-todo/**",
    "bench/fixtures/**",
    "rolldown/**",
    "vite/**"
  ],
  "packageRules": [
    {
      "description": "Disable all npm updates (lockfile updates fail because vite/patches/* is gitignored)",
      "matchManagers": ["npm"],
      "enabled": false
    },
    {
      "description": "Disable all cargo updates (lockfile updates fail because rolldown/ is gitignored)",
      "matchManagers": ["cargo"],
      "enabled": false
    }
  ]
}
